# ─── Tokens bots ───────────────────────────────────────────────
# Un seul token suffit pour lancer le bot correspondant.
# Pour lancer tous les bots dans le même service Railway, renseignez toutes les valeurs.

# Arcane (prefix: !)
ARCANE_TOKEN=

# Arcane Chan (prefix: !)
ARCANE_CHAN_TOKEN=

# Arcane Premium (prefix: !)
DISCORD_TOKEN=

# ProBot (prefix: +)
PROBOT_FREE_TOKEN=

# ProBot Premium (prefix: +)
PROBOT_TOKEN=

# Dyno (prefix: ?)
DYNO_TOKEN=

# Dyno Premium (prefix: ?)
DYNO_PREMIUM_TOKEN=

# Bot Support (prefix: !)
SUPPORT_TOKEN=

# ─── Support ────────────────────────────────────────────────────
# Adresse e-mail affichée par la commande /support
SUPPORT_EMAIL=

# ─── Divers ─────────────────────────────────────────────────────
# Facultatif en local. Sur Railway, le bot détecte automatiquement le chemin d'un Volume.
# DATA_DIR=./data
