# ─── Tokens bots ───────────────────────────────────────────────
# Un seul token suffit pour lancer le bot correspondant.
# Pour lancer les trois bots dans le même service Railway, renseignez les trois valeurs.
ARCANE_TOKEN=
ARCANE_CHAN_TOKEN=

# Token pour Arcane Premium
DISCORD_TOKEN=

# Token pour ProBot Premium
PROBOT_TOKEN=

# ─── Support ────────────────────────────────────────────────────
# Lien complet vers votre serveur Discord de support (affiché par /support)
SUPPORT_SERVER_URL=https://discord.gg/XXXXXXXXX

# Code d'invitation seul (ex: "arcane" pour discord.gg/arcane)
SUPPORT_INVITE_CODE=

# Adresse e-mail de support (optionnel)
SUPPORT_EMAIL=

# ─── Divers ─────────────────────────────────────────────────────
# Facultatif : le préfixe textuel est ! par défaut.
# PREFIX=!

# Facultatif en local. Sur Railway, le bot détecte automatiquement le chemin d'un Volume.
# DATA_DIR=./data
